<view class="page-shell">
  <!-- Hero -->
  <view class="hero animate-in">
    <view class="hero-badge">资料商城</view>
    <view class="hero-title">规划手册、资料包、模板，都可以直接下单。</view>
  </view>

  <!-- Tab 切换 -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'products' ? 'active' : ''}}" bindtap="switchTab" data-tab="products">商品</view>
    <view class="tab-item {{activeTab === 'cart' ? 'active' : ''}}" bindtap="switchTab" data-tab="cart">
      购物车<text wx:if="{{cartCount}}" class="tab-badge">{{cartCount}}</text>
    </view>
    <view class="tab-item {{activeTab === 'orders' ? 'active' : ''}}" bindtap="switchTab" data-tab="orders">我的订单</view>
  </view>

  <!-- 商品 Tab -->
  <block wx:if="{{activeTab === 'products'}}">
    <!-- 骨架屏 -->
    <block wx:if="{{loading}}">
      <view class="skeleton-card" wx:for="{{[1,2,3]}}" wx:key="*this">
        <view class="skeleton skeleton-title"></view>
        <view class="skeleton skeleton-text"></view>
        <view class="skeleton skeleton-text-short"></view>
      </view>
    </block>

    <view class="list" wx:if="{{!loading && products.length}}">
      <block wx:for="{{products}}" wx:key="id">
        <view class="card animate-in" style="animation-delay: {{index * 0.06}}s;">
          <!-- 商品图片 -->
          <image wx:if="{{item.imageUrl}}" src="{{item.imageUrl}}" mode="aspectFill" lazy-load
                 style="width: 100%; height: 280rpx; border-radius: 20rpx; background: #f3f4f6;" />

          <!-- 商品信息 -->
          <view class="item-title" style="margin-top: 16rpx;">{{item.title}}</view>
          <view class="item-meta">{{item.description}}</view>

          <!-- 价格和操作 -->
          <view style="display: flex; justify-content: space-between; align-items: center; margin-top: 16rpx;">
            <view style="display: flex; align-items: baseline; gap: 12rpx;">
              <text style="font-size: 36rpx; font-weight: 700; color: #dc2626;">¥{{item.price}}</text>
              <text class="muted" style="font-size: 24rpx;">库存 {{item.stock}}</text>
            </view>
            <button class="primary-button" style="margin-top: 0; padding: 14rpx 28rpx; font-size: 26rpx;"
                    bindtap="addToCart" data-id="{{item.id}}">
              加入购物车
            </button>
          </view>
        </view>
      </block>
    </view>

    <empty-state wx:if="{{!loading && loadError}}"
      icon="⚠️" title="加载失败" description="{{loadError}}" actionText="重试" bind:action="retry" />

    <empty-state wx:if="{{!loading && !loadError && products.length === 0}}"
      icon="🛍️" title="暂无商品" description="老师上架资料后，这里会显示商品列表" />
  </block>

  <!-- 购物车 Tab -->
  <block wx:if="{{activeTab === 'cart'}}">
    <view class="list" wx:if="{{cartItems.length}}">
      <block wx:for="{{cartItems}}" wx:key="id">
        <view class="card animate-in" style="animation-delay: {{index * 0.06}}s;">
          <view style="display: flex; gap: 20rpx;">
            <image wx:if="{{item.imageUrl}}" src="{{item.imageUrl}}" mode="aspectFill" lazy-load
                   style="width: 160rpx; height: 160rpx; border-radius: 16rpx; flex-shrink: 0; background: #f3f4f6;" />
            <view style="flex: 1; min-width: 0;">
              <view class="item-title">{{item.title}}</view>
              <view style="display: flex; justify-content: space-between; align-items: center; margin-top: 12rpx;">
                <text style="font-size: 32rpx; font-weight: 700; color: #dc2626;">¥{{item.price}}</text>
                <text class="muted">x{{item.quantity}}</text>
              </view>
            </view>
          </view>
          <view style="display: flex; justify-content: flex-end; margin-top: 12rpx;">
            <view class="danger-button" style="padding: 8rpx 20rpx; font-size: 24rpx;"
                  bindtap="removeCartItem" data-id="{{item.id}}">删除</view>
          </view>
        </view>
      </block>

      <!-- 地址选择 -->
      <view class="section" style="margin-top: 24rpx;">
        <view style="display: flex; justify-content: space-between; align-items: center;">
          <view class="section-title">收货地址</view>
          <text style="font-size: 26rpx; color: #2563eb;" bindtap="toggleAddressForm">
            {{showAddressForm ? '收起' : '+ 新增地址'}}
          </text>
        </view>

        <!-- 地址列表 -->
        <view wx:if="{{addresses.length}}" class="list" style="margin-top: 12rpx;">
          <view wx:for="{{addresses}}" wx:key="id"
                class="list-item" bindtap="selectAddress" data-id="{{item.id}}"
                style="{{selectedAddressId === item.id ? 'border-color: #2563eb; background: #eff6ff;' : ''}}">
            <view style="display: flex; align-items: center; gap: 8rpx;">
              <text wx:if="{{item.is_default}}" style="font-size: 20rpx; color: #fff; background: #2563eb; padding: 2rpx 10rpx; border-radius: 6rpx;">默认</text>
              <text style="font-weight: 600;">{{item.name}}</text>
              <text class="muted">{{item.phone}}</text>
            </view>
            <view class="item-meta">{{item.address}}</view>
          </view>
        </view>

        <!-- 新增地址表单 -->
        <view wx:if="{{showAddressForm}}" style="margin-top: 16rpx; padding: 20rpx; background: #f9fafb; border-radius: 20rpx;">
          <input class="input" placeholder="姓名" value="{{newAddress.name}}" data-field="name" bindinput="handleAddressFormInput" style="margin-top: 0;" />
          <input class="input" placeholder="手机号" type="number" value="{{newAddress.phone}}" data-field="phone" bindinput="handleAddressFormInput" />
          <textarea class="textarea" placeholder="详细地址" value="{{newAddress.address}}" data-field="address" bindinput="handleAddressFormInput" style="min-height: 100rpx;"></textarea>
          <view style="display: flex; align-items: center; gap: 8rpx; margin-top: 8rpx;" bindtap="toggleDefaultAddress">
            <view style="width: 32rpx; height: 32rpx; border-radius: 6rpx; border: 2rpx solid {{newAddress.isDefault ? '#2563eb' : '#d1d5db'}}; background: {{newAddress.isDefault ? '#2563eb' : 'transparent'}}; display: flex; align-items: center; justify-content: center;">
              <text wx:if="{{newAddress.isDefault}}" style="color: #fff; font-size: 20rpx;">✓</text>
            </view>
            <text style="font-size: 26rpx; color: #6b7280;">设为默认地址</text>
          </view>
          <button class="primary-button" style="margin-top: 16rpx;" bindtap="saveAddress" disabled="{{savingAddress}}">{{savingAddress ? '保存中...' : '保存地址'}}</button>
        </view>
      </view>

      <!-- 结账按钮 -->
      <button class="primary-button" style="margin-top: 24rpx; width: 100%;" bindtap="checkout" disabled="{{submitting}}">
        {{submitting ? '提交中...' : '结账（' + cartCount + '件）'}}
      </button>
    </view>

    <empty-state wx:if="{{cartItems.length === 0}}"
      icon="🛒" title="购物车是空的" description="去商品区逛逛吧" actionText="去逛逛" bind:action="goProducts" />
  </block>

  <!-- 订单 Tab -->
  <block wx:if="{{activeTab === 'orders'}}">
    <view class="list" wx:if="{{orders.length}}">
      <block wx:for="{{orders}}" wx:key="id">
        <view class="card animate-in" style="animation-delay: {{index * 0.06}}s;">
          <view style="display: flex; justify-content: space-between; align-items: center;">
            <view class="item-title">{{item.productTitle}}</view>
            <view style="font-size: 24rpx; padding: 4rpx 16rpx; border-radius: 999rpx; background: {{item.status === 'delivered' ? '#dcfce7' : (item.status === 'shipped' ? '#fff7ed' : '#eff6ff')}}; color: {{item.status === 'delivered' ? '#16a34a' : (item.status === 'shipped' ? '#ea580c' : '#2563eb')}};">
              {{item.status === 'paid' ? '已支付' : (item.status === 'shipped' ? '已发货' : (item.status === 'delivered' ? '已送达' : item.status))}}
            </view>
          </view>
          <view class="item-meta">
            数量 {{item.quantity}} · 金额 ¥{{item.totalAmount}}
          </view>
          <view class="item-meta">{{item.shippingAddress}}</view>
        </view>
      </block>
    </view>

    <empty-state wx:if="{{orders.length === 0}}"
      icon="📦" title="还没有订单" description="购买资料后，订单会显示在这里" actionText="去购物" bind:action="goProducts" />
  </block>
</view>
