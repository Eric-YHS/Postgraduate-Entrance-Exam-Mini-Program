<view class="page-shell">
  <!-- 骨架屏 -->
  <block wx:if="{{loading}}">
    <view class="skeleton skeleton-hero"></view>
    <view class="skeleton-card">
      <view class="skeleton skeleton-title"></view>
      <view class="skeleton skeleton-text"></view>
    </view>
  </block>

  <block wx:if="{{!loading && course}}">
    <!-- 视频播放器 -->
    <view class="video-container animate-in">
      <video id="courseVideo" class="video-player" src="{{course.videoSrc}}" controls
             initial-time="{{playPosition}}" enable-progress-gesture
             bindtimeupdate="onTimeUpdate" bindended="onVideoEnded" bindplay="onVideoPlay" />
    </view>

    <!-- 课程信息 -->
    <view class="section animate-in" style="animation-delay: 0.06s;">
      <view style="display: flex; justify-content: space-between; align-items: flex-start;">
        <view class="badge">{{course.subject}}</view>
        <text class="muted" style="font-size: 24rpx;">{{progressText}}</text>
      </view>
      <view class="item-title" style="margin-top: 12rpx;">{{course.title}}</view>
      <view class="item-meta" wx:if="{{course.description}}" style="margin-top: 8rpx;">{{course.description}}</view>

      <!-- 进度条 -->
      <view class="progress-bar" style="margin-top: 16rpx;">
        <view class="progress-fill" style="width: {{progressPercent}}%;"></view>
      </view>
      <text style="font-size: 22rpx; color: #6b7280; margin-top: 6rpx; display: block;">已观看 {{progressPercent}}%</text>
    </view>

    <!-- 课程笔记区 -->
    <view class="section animate-in" style="animation-delay: 0.12s;">
      <view class="section-title">课程笔记</view>
      <textarea class="textarea" placeholder="记录学习要点..." value="{{noteContent}}" bindinput="onNoteInput" maxlength="2000"></textarea>
      <button class="primary-button" bindtap="saveNote" disabled="{{savingNote}}" style="margin-top: 12rpx;">
        {{savingNote ? '保存中...' : '保存笔记'}}
      </button>

      <!-- 已有笔记 -->
      <view class="list" wx:if="{{notes.length}}" style="margin-top: 16rpx;">
        <block wx:for="{{notes}}" wx:key="id">
          <view class="list-item">
            <view class="item-meta">{{item.content}}</view>
            <text class="muted" style="font-size: 22rpx; margin-top: 8rpx; display: block;">{{item.createdAt}}</text>
          </view>
        </block>
      </view>
    </view>
  </block>
</view>
