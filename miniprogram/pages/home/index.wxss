/* 首页局部样式 */
.primary-button,
.ghost-button,
.nav-button {
  margin-right: 12rpx;
}

/* 核心指标 */
.core-stats {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.core-stat {
  flex: 1;
  text-align: center;
  padding: 16rpx 8rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.15);
  border: 2rpx solid rgba(255, 255, 255, 0.25);
}

.core-stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
}

.core-stat-label {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.live-dot::before {
  content: '';
  display: inline-block;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ef4444;
  margin-right: 8rpx;
  vertical-align: middle;
}

/* 行动入口网格 */
.action-grid {
  display: grid;
  gap: 16rpx;
  margin-top: 20rpx;
}

.action-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  transition: transform 0.15s, box-shadow 0.15s;
}

.action-card:active {
  transform: scale(0.98);
  background: #f0f5ff;
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.action-info {
  flex: 1;
  min-width: 0;
}

.action-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.action-desc {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.action-arrow {
  font-size: 36rpx;
  color: #9ca3af;
  flex-shrink: 0;
}
