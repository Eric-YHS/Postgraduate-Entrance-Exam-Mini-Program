<view class="page-shell">
  <!-- 骨架屏 -->
  <block wx:if="{{loading}}">
    <view class="skeleton skeleton-hero"></view>
    <view class="skeleton-card">
      <view class="skeleton skeleton-title"></view>
      <view class="skeleton skeleton-text"></view>
      <view class="skeleton skeleton-text-short"></view>
    </view>
    <view class="skeleton-card">
      <view class="skeleton skeleton-title"></view>
      <view class="skeleton skeleton-text"></view>
      <view class="skeleton skeleton-text-short"></view>
    </view>
  </block>

  <!-- 全页错误 -->
  <block wx:if="{{!loading && pageError}}">
    <empty-state
      icon="⚠️"
      title="页面加载失败"
      description="{{pageError}}"
      actionText="重试"
      bind:action="retryPage" />
  </block>

  <block wx:if="{{!loading && !pageError}}">
    <!-- 第一屏：核心状态 -->
    <view class="hero animate-in">
      <view class="hero-badge">今日考研规划</view>
      <view class="hero-title">{{user.displayName}}，今天的复习节奏已经排好了。</view>

      <!-- 核心指标 -->
      <view class="core-stats">
        <view class="core-stat" bindtap="scrollToTasks">
          <text class="core-stat-value">{{tasksCompleted}}/{{tasks.length}}</text>
          <text class="core-stat-label">任务完成</text>
        </view>
        <view class="core-stat">
          <text class="core-stat-value">{{unreadCount}}</text>
          <text class="core-stat-label">未读提醒</text>
        </view>
        <view class="core-stat" wx:if="{{nearestLive}}" bindtap="openLive" data-id="{{nearestLive.id}}">
          <text class="core-stat-value live-dot">{{nearestLive.status === 'live' ? '直播中' : '即将开始'}}</text>
          <text class="core-stat-label">{{nearestLive.title}}</text>
        </view>
      </view>

      <!-- 搜索入口 -->
      <view class="search-bar search-bar--hero" bindtap="goSearch">
        <text class="search-icon">🔍</text>
        <text class="search-bar--hero-text">搜索帖子、题目、课程...</text>
      </view>

      <!-- 更新时间 -->
      <view class="update-time">最后更新: {{lastUpdateTime}}</view>
    </view>

    <!-- 第二屏：行动入口 -->
    <view class="section animate-in" style="animation-delay: 0.06s;">
      <view class="section-title">下一步行动</view>
      <view class="action-grid">
        <!-- 主卡：完成今日任务 -->
        <view class="action-card action-card--primary" bindtap="scrollToTasks" wx:if="{{tasks.length > tasksCompleted}}">
          <view class="action-icon action-icon--brand">📋</view>
          <view class="action-info">
            <view class="action-title">完成今日任务</view>
            <view class="action-desc">还有 {{tasks.length - tasksCompleted}} 项待完成</view>
          </view>
          <view class="action-arrow">›</view>
        </view>

        <!-- 次卡：继续刷题 -->
        <view class="action-card action-card--secondary" bindtap="goQuestions">
          <view class="action-icon action-icon--neutral">📝</view>
          <view class="action-info">
            <view class="action-title">开始刷题</view>
            <view class="action-desc">练习题目，暴露薄弱点</view>
          </view>
          <view class="action-arrow">›</view>
        </view>

        <!-- 次卡：继续课程 -->
        <view class="action-card action-card--secondary" bindtap="goCourses">
          <view class="action-icon action-icon--neutral">🎬</view>
          <view class="action-info">
            <view class="action-title">继续课程</view>
            <view class="action-desc">{{recentCourseTitle || '查看录播课程'}}</view>
          </view>
          <view class="action-arrow">›</view>
        </view>

        <!-- 次卡：词汇复习 -->
        <view class="action-card action-card--secondary" bindtap="goFlashcards">
          <view class="action-icon action-icon--neutral">🃏</view>
          <view class="action-info">
            <view class="action-title">词汇复习</view>
            <view class="action-desc">利用间隔重复巩固记忆</view>
          </view>
          <view class="action-arrow">›</view>
        </view>
      </view>
    </view>

    <!-- 今日任务（精简列表） -->
    <view class="section animate-in" id="task-section" style="animation-delay: 0.12s;">
      <view class="section-title">今日任务 ({{tasksCompleted}}/{{tasks.length}})</view>
      <view class="list" wx:if="{{tasks.length}}">
        <block wx:for="{{tasks}}" wx:key="id">
          <view class="list-item {{item.completedAt ? 'list-item--done' : ''}}">
            <view class="task-row">
              <view class="task-checkbox {{item.completedAt ? 'task-checkbox--done' : ''}}"
                    bindtap="toggleTaskComplete" data-id="{{item.id}}" data-completed="{{item.completedAt}}">
                <text wx:if="{{item.completedAt}}" class="task-checkbox-check">✓</text>
              </view>
              <view class="task-content">
                <view class="badge">{{item.subject}}</view>
                <view class="item-title {{item.completedAt ? 'task-title--done' : ''}}">{{item.title}}</view>
                <view class="item-meta" wx:if="{{item.startTime !== '00:00' && item.endTime !== '23:59'}}">{{item.startTime}} - {{item.endTime}}</view>
                <!-- 子任务列表 -->
                <view wx:if="{{item.subtasks && item.subtasks.length}}" style="margin-top:8rpx;padding:8rpx 12rpx;background:#f8fafc;border-radius:8rpx;">
                  <view style="font-size:22rpx;color:#64748b;margin-bottom:4rpx;">子任务 {{item.subtasksCompleted}}/{{item.subtasks.length}}</view>
                  <block wx:for="{{item.subtasks}}" wx:for-item="st" wx:key="id">
                    <view style="display:flex;align-items:center;gap:6rpx;padding:4rpx 0;" bindtap="toggleSubtask" data-id="{{st.id}}" data-completed="{{st.completed}}">
                      <text style="font-size:28rpx;">{{st.completed ? '☑' : '☐'}}</text>
                      <text style="font-size:24rpx;{{st.completed ? 'text-decoration:line-through;color:#94a3b8;' : ''}}">{{st.title}}</text>
                    </view>
                  </block>
                </view>
                <!-- 提醒时间 -->
                <view wx:if="{{item.reminderStart && item.reminderEnd}}" style="margin-top:6rpx;font-size:22rpx;color:#6366f1;">
                  ⏰ {{item.myReminderTime ? '已设提醒 ' + item.myReminderTime : '可设提醒 ' + item.reminderStart + '-' + item.reminderEnd}}
                </view>
              </view>
            </view>
          </view>
        </block>
      </view>
      <empty-state wx:else
        icon="📋"
        title="今天没有待办任务"
        description="所有任务已完成或今天没有安排"
        actionText="去刷题"
        bind:action="goQuestions" />
    </view>

    <!-- 提交今日总结 -->
    <view class="section animate-in" id="summary-section" style="animation-delay: 0.18s;">
      <view class="section-title">今日总结</view>
      <input class="input" type="date" value="{{summaryDate}}" data-field="summaryDate" bindinput="handleSummaryInput" />
      <textarea class="textarea" placeholder="写下今天的完成情况、薄弱点和明天要补什么" value="{{summaryContent}}" data-field="summaryContent" bindinput="handleSummaryInput" maxlength="2000"></textarea>
      <view class="inline-actions">
        <button class="ghost-button" bindtap="chooseImages">选择图片</button>
        <button class="ghost-button" bindtap="chooseFiles">选择附件</button>
        <button class="primary-button" bindtap="submitSummary" disabled="{{submittingSummary}}">{{submittingSummary ? '提交中...' : '提交总结'}}</button>
      </view>
      <view class="empty-text" wx:if="{{selectedImages.length || selectedFiles.length}}">已选图片 {{selectedImages.length}} 张，附件 {{selectedFiles.length}} 个</view>
    </view>

    <!-- 第三屏：补充信息（可折叠） -->
    <view class="section animate-in" style="animation-delay: 0.24s;">
      <view class="section-toggle" bindtap="toggleSupplement">
        <view class="section-title">更多信息</view>
        <text class="section-toggle-arrow">{{expandSupplement ? '收起 ▴' : '展开 ▾'}}</text>
      </view>

      <block wx:if="{{expandSupplement}}">
        <!-- 提醒中心 -->
        <view class="sub-section">
          <view class="section-toggle">
            <text class="sub-section-title">提醒中心</text>
            <text wx:if="{{notifications.length}}" class="sub-section-title-link" bindtap="markAllRead">全部已读</text>
          </view>
          <view class="list" wx:if="{{notifications.length}}" style="margin-top: 12rpx;">
            <block wx:for="{{notifications}}" wx:key="id">
              <view class="list-item {{item.readAt ? 'list-item--done' : ''}}">
                <view class="item-title">{{item.title}}</view>
                <view class="item-meta">{{item.body}}</view>
                <view class="inline-actions">
                  <view class="badge">{{item.type}}</view>
                  <button wx:if="{{!item.readAt}}" class="ghost-button" size="mini" data-id="{{item.id}}" bindtap="markNotificationRead">已读</button>
                </view>
              </view>
            </block>
          </view>
          <view wx:else class="empty-hint">暂无提醒</view>
        </view>

        <!-- 论坛交流 -->
        <view class="sub-section">
          <text class="sub-section-title">论坛交流</text>
          <view style="margin-top: 12rpx;">
            <button class="ghost-button" bindtap="goForum">进入论坛</button>
          </view>
        </view>

        <!-- 直播入口 -->
        <view class="sub-section" wx:if="{{liveSessions.length}}">
          <text class="sub-section-title">直播入口</text>
          <view class="list" style="margin-top: 12rpx;">
            <block wx:for="{{liveSessions}}" wx:key="id">
              <view class="list-item">
                <view class="section-toggle">
                  <view>
                    <view class="item-title">{{item.title}}</view>
                  </view>
                  <view class="live-status {{item.status === 'live' ? 'live-status--active' : 'live-status--upcoming'}}">
                    {{item.status === 'live' ? '直播中' : (item.status === 'ended' ? '已结束' : '待开始')}}
                  </view>
                </view>
                <view style="margin-top: 16rpx;">
                  <button class="primary-button" data-id="{{item.id}}}" bindtap="openLive"
                          disabled="{{item.status === 'ended'}}">
                    {{item.status === 'live' ? '进入' : (item.status === 'ended' ? '已结束' : '预约')}}
                  </button>
                </view>
              </view>
            </block>
          </view>
        </view>

        <!-- 历史总结（最多显示3条） -->
        <view class="sub-section">
          <text class="sub-section-title">历史总结</text>
          <view class="list" wx:if="{{summaries.length}}" style="margin-top: 12rpx;">
            <block wx:for="{{summaries}}" wx:key="id" wx:if="{{index < 3}}">
              <view class="list-item">
                <view class="item-title">{{item.taskDate}}</view>
                <view class="item-meta">{{item.content}}</view>
                <view wx:if="{{item.teacherComment}}" style="margin-top:8rpx;padding:12rpx 16rpx;background:#eff6ff;border-radius:12rpx;border-left:4rpx solid #3b82f6;">
                  <text style="font-size:22rpx;color:#3b82f6;font-weight:600;">老师点评：</text>
                  <text style="font-size:24rpx;color:#1e293b;">{{item.teacherComment}}</text>
                </view>
              </view>
            </block>
          </view>
          <view wx:else class="empty-hint">暂无历史总结</view>
        </view>
      </block>
    </view>
  </block>
</view>
