.wx-login-btn {
  margin-top: 20rpx;
  background-color: #07c160;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  line-height: 96rpx;
}

.full-width {
  margin-top: 24rpx;
  width: 100%;
  text-align: center;
}

.divider {
  display: flex;
  align-items: center;
  margin: 32rpx 0;
}

.divider-line {
  flex: 1;
  height: 2rpx;
  background: #d1d5db;
}

.divider-text {
  padding: 0 24rpx;
  color: #9ca3af;
  font-size: 26rpx;
}

/* 输入验证样式 */
.input-valid {
  border-color: #22c55e !important;
}

.input-check {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(25%);
  color: #22c55e;
  font-size: 32rpx;
  font-weight: bold;
}
