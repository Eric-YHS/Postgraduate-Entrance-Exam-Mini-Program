/* 题库页面局部样式 */
.primary-button {
  margin-top: 20rpx;
}

/* 进度头部 */
.progress-header {
  padding: 20rpx 26rpx;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.progress-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

.progress-stats {
  font-size: 24rpx;
  color: #16a34a;
}

/* 单题卡片 */
.question-card {
  padding: 28rpx;
}

/* 选项样式 */
.option-item {
  padding: 20rpx;
  margin-bottom: 12rpx;
  border-radius: 18rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  transition: all 0.15s;
}

.option-selected {
  background: #eff6ff;
  border-color: #2563eb;
}

.option-correct {
  background: #dcfce7;
  border-color: #86efac;
}

.option-wrong {
  background: #fef2f2;
  border-color: #fca5a5;
}

/* 答题结果面板 */
.result-panel {
  padding: 24rpx;
  border-radius: 18rpx;
  border-left: 6rpx solid;
}

.result-correct {
  background: #f0fdf4;
  border-left-color: #16a34a;
}

.result-wrong {
  background: #fef2f2;
  border-left-color: #dc2626;
}

.result-header {
  font-size: 30rpx;
  font-weight: 700;
}

.result-correct .result-header {
  color: #16a34a;
}

.result-wrong .result-header {
  color: #dc2626;
}

.result-analysis {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #374151;
  line-height: 1.7;
}

/* 会话统计 */
.session-stats {
  display: flex;
  gap: 20rpx;
  justify-content: center;
  margin-top: 24rpx;
}

.session-stat {
  text-align: center;
  padding: 16rpx 24rpx;
  border-radius: 18rpx;
  background: #f9fafb;
}

.session-stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
}

.session-stat-label {
  display: block;
  font-size: 22rpx;
  color: #6b7280;
  margin-top: 4rpx;
}
