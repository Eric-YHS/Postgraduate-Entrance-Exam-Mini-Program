<view class="page-shell">
  <!-- 骨架屏 -->
  <block wx:if="{{loading}}">
    <view class="skeleton-card">
      <view class="skeleton skeleton-title"></view>
      <view class="skeleton skeleton-text"></view>
      <view class="skeleton skeleton-text"></view>
      <view class="skeleton skeleton-text-short"></view>
    </view>
  </block>

  <block wx:if="{{!loading && topic}}">
    <!-- 帖子内容 -->
    <view class="card animate-in">
      <!-- 头部 -->
      <view style="display: flex; justify-content: space-between; align-items: center;">
        <view style="display: flex; align-items: center; gap: 12rpx;">
          <view class="badge">{{topic.category}}</view>
          <view wx:if="{{topic.isPinned}}" style="font-size: 22rpx; color: #ea580c;">📌 置顶</view>
        </view>
        <text class="muted" style="font-size: 22rpx;">{{topic.authorName}} · {{topic.createdAt}}</text>
      </view>

      <!-- 标题和内容 -->
      <view class="item-title" style="margin-top: 16rpx;">{{topic.title}}</view>
      <view class="item-meta" style="margin-top: 12rpx; line-height: 1.8;">{{topic.content}}</view>

      <!-- 图片 -->
      <view wx:if="{{topic.imageUrls.length}}" style="display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 20rpx;">
        <image wx:for="{{topic.imageUrls}}" wx:for-item="imgUrl" wx:key="*this"
               src="{{imgUrl}}" mode="aspectFill" lazy-load
               style="width: 200rpx; height: 200rpx; border-radius: 16rpx; background: #f3f4f6;"
               bindtap="previewImage" data-url="{{imgUrl}}" data-urls="{{topic.imageUrls}}" />
      </view>

      <!-- 话题标签 -->
      <view wx:if="{{topic.hashtags && topic.hashtags.length}}" style="display: flex; flex-wrap: wrap; gap: 8rpx; margin-top: 16rpx;">
        <text wx:for="{{topic.hashtags}}" wx:for-item="tag" wx:key="*this"
              style="font-size: 22rpx; color: #2563eb; background: #eff6ff; padding: 4rpx 16rpx; border-radius: 999rpx;">
          #{{tag}}
        </text>
      </view>

      <!-- 互动栏 -->
      <view style="display: flex; align-items: center; gap: 32rpx; margin-top: 20rpx; padding-top: 16rpx; border-top: 2rpx solid #f3f4f6;">
        <view class="fav-btn {{topic.likedByMe ? 'active' : ''}}" bindtap="toggleLike"
              style="color: {{topic.likedByMe ? '#ef4444' : '#9ca3af'}};">
          {{topic.likedByMe ? '❤️' : '🤍'}} {{topic.likeCount || 0}}
        </view>
        <view style="font-size: 24rpx; color: #6b7280;">
          💬 {{replies.length}}
        </view>
      </view>
    </view>

    <!-- 回复列表 -->
    <view class="section animate-in" style="animation-delay: 0.06s;">
      <view class="section-title">回复 ({{replies.length}})</view>

      <view class="list" wx:if="{{replies.length}}" style="margin-top: 16rpx;">
        <block wx:for="{{replies}}" wx:key="id">
          <view class="list-item" style="{{item.replyToUser ? 'border-left: 4rpx solid #2563eb; padding-left: 20rpx;' : ''}}">
            <view style="display: flex; justify-content: space-between; align-items: center;">
              <text style="font-size: 26rpx; font-weight: 600; color: #374151;">{{item.authorName}}</text>
              <text class="muted" style="font-size: 22rpx;">{{item.createdAt}}</text>
            </view>
            <view wx:if="{{item.replyToUser}}" style="font-size: 22rpx; color: #6b7280; margin-top: 4rpx;">
              回复 @{{item.replyToUser}}
            </view>
            <view class="item-meta" style="margin-top: 8rpx;">{{item.content}}</view>
          </view>
        </block>
      </view>

      <view wx:if="{{replies.length === 0}}" style="padding: 40rpx; text-align: center; color: #9ca3af; font-size: 26rpx;">
        暂无回复，来说点什么吧
      </view>
    </view>

    <!-- 回复输入 -->
    <view class="reply-bar animate-in" style="animation-delay: 0.12s;">
      <textarea class="textarea" placeholder="回复这条帖子..." value="{{replyContent}}"
                bindinput="onReplyInput" auto-height style="flex: 1; min-height: 80rpx; margin-top: 0;" />
      <button class="primary-button" bindtap="submitReply" disabled="{{submittingReply}}" style="margin-top: 0; padding: 16rpx 24rpx; white-space: nowrap;">
        {{submittingReply ? '发送中...' : '发送'}}
      </button>
    </view>
  </block>
</view>
