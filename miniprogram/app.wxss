page {
  --bg-primary: #f0f5ff;
  --bg-card: #ffffff;
  --text-primary: #1f2937;
  --text-muted: #6b7280;
  --border-color: #e5e7eb;
  --color-blue: #2563eb;
  --color-blue-light: #3b82f6;
  --color-red: #dc2626;
  --color-green: #16a34a;
  --color-orange: #ea580c;
  /* 语义别名：与 Web 端 styles.css 对齐 */
  --brand: var(--color-blue);
  --danger: var(--color-red);
  --success: var(--color-green);
  --warning: var(--color-orange);

  background: var(--bg-primary);
  color: var(--text-primary);
  font-size: 28rpx;
}

.page-shell {
  padding: 28rpx;
}

.hero {
  padding: 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
  color: #fff;
  box-shadow: 0 24rpx 60rpx rgba(37, 99, 235, 0.15);
}

.hero-badge,
.badge {
  display: inline-block;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.20);
  border: 2rpx solid rgba(255, 255, 255, 0.30);
  font-size: 22rpx;
}

.hero-title {
  margin-top: 20rpx;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.25;
}

.hero-desc {
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.90);
  line-height: 1.7;
}

.nav-row,
.inline-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}

.nav-button,
.primary-button,
.ghost-button,
.danger-button {
  padding: 18rpx 26rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  line-height: 1;
}

.nav-button {
  color: #fff;
  background: rgba(255, 255, 255, 0.18);
  border: 2rpx solid rgba(255, 255, 255, 0.45);
}

.primary-button {
  color: #fff;
  background: #2563eb;
  border: 2rpx solid #1d4ed8;
}

.ghost-button {
  color: #2563eb;
  background: #ffffff;
  border: 2rpx solid #2563eb;
}

.danger-button {
  color: #b91c1c;
  background: #ffffff;
  border: 2rpx solid #b91c1c;
}

.card,
.section {
  margin-top: 24rpx;
  padding: 26rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
}

.muted {
  color: #6b7280;
}

.input,
.textarea {
  width: 100%;
  padding: 22rpx;
  margin-top: 12rpx;
  border-radius: 22rpx;
  background: #fff;
  border: 2rpx solid #d1d5db;
  transition: border-color 0.2s, box-shadow 0.2s;
}

.input:focus,
.textarea:focus {
  border-color: #2563eb;
  box-shadow: 0 0 0 4rpx rgba(37, 99, 235, 0.1);
}

.textarea {
  min-height: 180rpx;
}

.list {
  display: grid;
  gap: 20rpx;
  margin-top: 20rpx;
}

.list-item {
  padding: 22rpx;
  border-radius: 24rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
}

.item-title {
  font-size: 32rpx;
  font-weight: 700;
}

.item-meta {
  margin-top: 10rpx;
  color: #6b7280;
  line-height: 1.7;
}

.stats {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.stat-card {
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.18);
  border: 2rpx solid rgba(255, 255, 255, 0.30);
}

.stat-value {
  display: block;
  margin-top: 12rpx;
  font-size: 46rpx;
  font-weight: 700;
}

.media-preview {
  width: 100%;
  border-radius: 24rpx;
  margin-top: 20rpx;
}

.empty-text {
  margin-top: 16rpx;
  color: #6b7280;
}

/* ========== 骨架屏 ========== */
@keyframes shimmer {
  0% { background-position: -400rpx 0; }
  100% { background-position: 400rpx 0; }
}

.skeleton {
  background: linear-gradient(90deg, #e5e7eb 25%, #f3f4f6 50%, #e5e7eb 75%);
  background-size: 400rpx 100%;
  animation: shimmer 1.5s ease-in-out infinite;
  border-radius: 16rpx;
}

.skeleton-hero {
  height: 200rpx;
  border-radius: 32rpx;
  margin-bottom: 24rpx;
}

.skeleton-card {
  padding: 26rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  margin-top: 24rpx;
}

.skeleton-title {
  height: 36rpx;
  width: 60%;
  margin-bottom: 16rpx;
}

.skeleton-text {
  height: 28rpx;
  width: 100%;
  margin-bottom: 12rpx;
}

.skeleton-text-short {
  height: 28rpx;
  width: 40%;
  margin-bottom: 12rpx;
}

.skeleton-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
}

.skeleton-line {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.skeleton-option {
  height: 64rpx;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

/* ========== 筛选栏 ========== */
.filter-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.filter-pill {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  background: #ffffff;
  color: #374151;
  border: 2rpx solid #e5e7eb;
  transition: all 0.2s;
}

.filter-pill.active {
  background: #2563eb;
  color: #ffffff;
  border-color: #2563eb;
}

/* ========== 搜索栏 ========== */
.search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  background: #ffffff;
  border-radius: 999rpx;
  border: 2rpx solid #e5e7eb;
  margin-top: 20rpx;
}

.search-bar input {
  flex: 1;
  font-size: 28rpx;
}

.search-icon {
  font-size: 32rpx;
  color: #9ca3af;
}

/* ========== Tab 切换 ========== */
.tab-bar {
  display: flex;
  border-bottom: 2rpx solid #e5e7eb;
  margin-top: 20rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #6b7280;
  position: relative;
}

.tab-item.active {
  color: #2563eb;
  font-weight: 700;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: #2563eb;
}

.tab-badge {
  display: inline-block;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  font-size: 20rpx;
  color: #fff;
  background: #ef4444;
  border-radius: 999rpx;
  padding: 0 8rpx;
  margin-left: 6rpx;
  vertical-align: middle;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.empty-state-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-state-text {
  color: #6b7280;
  font-size: 28rpx;
  text-align: center;
  line-height: 1.6;
}

.empty-state-action {
  margin-top: 32rpx;
}

/* ========== 收藏按钮 ========== */
.fav-btn {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: #9ca3af;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
}

.fav-btn.active {
  color: #f59e0b;
  background: #fffbeb;
}

/* ========== 微交互动画 ========== */
@keyframes fadeSlideUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-in {
  animation: fadeSlideUp 0.35s ease-out both;
}

.animate-in-delay-1 { animation-delay: 0.08s; }
.animate-in-delay-2 { animation-delay: 0.16s; }
.animate-in-delay-3 { animation-delay: 0.24s; }

/* 按钮按压效果 */
.primary-button:active,
.ghost-button:active,
.nav-button:active,
.danger-button:active {
  transform: scale(0.96);
  opacity: 0.9;
}

/* 答题结果动画 */
@keyframes correctPop {
  0% { transform: scale(0.5); opacity: 0; }
  60% { transform: scale(1.2); }
  100% { transform: scale(1); opacity: 1; }
}

@keyframes wrongShake {
  0%, 100% { transform: translateX(0); }
  20%, 60% { transform: translateX(-10rpx); }
  40%, 80% { transform: translateX(10rpx); }
}

.result-correct {
  animation: correctPop 0.4s ease-out;
}

.result-wrong {
  animation: wrongShake 0.4s ease-out;
}

/* ========== 进度条 ========== */
.progress-bar {
  height: 8rpx;
  background: #e5e7eb;
  border-radius: 4rpx;
  overflow: hidden;
  margin-top: 12rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #2563eb, #3b82f6);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

/* ========== 分隔线 ========== */
.divider {
  height: 2rpx;
  background: #e5e7eb;
  margin: 20rpx 0;
}

/* ========== 统计网格 ========== */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 20rpx;
}

.stats-grid .stat-item {
  text-align: center;
  padding: 20rpx 8rpx;
  border-radius: 20rpx;
  background: #f9fafb;
}

.stats-grid .stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #2563eb;
}

.stats-grid .stat-label {
  font-size: 22rpx;
  color: #6b7280;
  margin-top: 8rpx;
}

/* ========== 快捷入口网格 ========== */
.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 20rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 0;
}

.quick-icon {
  width: 88rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 40rpx;
  border-radius: 24rpx;
  background: #eff6ff;
}

.quick-label {
  font-size: 22rpx;
  color: #374151;
}
