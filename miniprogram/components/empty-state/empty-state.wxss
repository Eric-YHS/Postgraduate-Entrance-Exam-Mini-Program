.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
  text-align: center;
}

.empty-state-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
}

.empty-state-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 12rpx;
}

.empty-state-desc {
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.empty-state-action {
  font-size: 26rpx;
  padding: 12rpx 36rpx;
  background: transparent;
  color: var(--brand, #2563eb);
  border: 1rpx solid var(--brand, #2563eb);
  border-radius: 16rpx;
  line-height: 1.5;
}
